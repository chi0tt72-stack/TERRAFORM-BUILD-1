# Ansible inventory - generated by Terraform (see environments/dev/ansible.tf)
# Copy to terraform_hosts.ini after 'terraform apply', or let Terraform create it.
# Use the same SSH key you use for EC2 (e.g. ~/.ssh/terraform-course-key).

[dev_instances]
instance_1 ansible_host=1.2.3.4

[dev_instances:vars]
ansible_user=ec2-user
# ansible_ssh_private_key_file=~/.ssh/terraform-course-key
